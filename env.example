# Bandwidth Monitor configuration
# This file should be chmod 0600 and owned by root
# Copy to /opt/bandwidth-monitor/.env

## Core

# Web server binding (host:port). Use :8080 to bind all interfaces.
LISTEN=:8080

# Choose web server protocol: http or https.
# HTTP example (default):
LISTEN_PROTOCOL=http

# Enable promiscuous mode for packet capture (true/false).
PROMISCUOUS=true

# HTTPS example:
# LISTEN=:8443
# LISTEN_PROTOCOL=https
# TLS certificate and private key are required when LISTEN_PROTOCOL=https.
# TLS_CERT_FILE=/etc/bandwidth-monitor/server.crt
# TLS_KEY_FILE=/etc/bandwidth-monitor/server.key

## Interface Selection

# Comma-separated list of interfaces to monitor and display.
# Controls both the web UI and packet capture (top talkers).
# If not set, all interfaces (except loopback) are used.
# INTERFACES=eth0,ppp0,wg0,br-lan

# Explicitly mark interface(s) as WAN uplink.
# Useful for double-NAT setups where the WAN interface has a private IP.
# If not set, WAN is auto-detected (public IPv4, PPP type, or default route).
# WAN_INTERFACE=eth0

## GeoIP

# GeoIP MMDB paths (relative to WorkingDirectory)
# City DB includes country, city, and coordinates for map visualization.
# Falls back to Country DB if City is unavailable.
# GEO_CITY=GeoLite2-City.mmdb
# GEO_ASN=GeoLite2-ASN.mmdb

## DNS Provider (choose one)

# AdGuard Home
# ADGUARD_URL=http://adguard.example.local
# ADGUARD_USER=your_username
# ADGUARD_PASS=your_password

# NextDNS (alternative to AdGuard Home)
# NEXTDNS_PROFILE=abc123
# NEXTDNS_API_KEY=your_api_key

# Pi-hole v6 (alternative to AdGuard Home / NextDNS)
# PIHOLE_URL=http://pi.hole
# PIHOLE_PASSWORD=your_password

## WiFi Provider (choose one)

# UniFi controller (mutually exclusive with Omada)
# UNIFI_URL=https://unifi.example.local:8443
# UNIFI_USER=your_username
# UNIFI_PASS=your_password
# UNIFI_SITE=default

# TP-Link Omada controller (mutually exclusive with UniFi)
# OMADA_URL=https://omada.example.local
# OMADA_USER=your_username
# OMADA_PASS=your_password
# OMADA_SITE=Default

## Network And VPN

# VPN routing status files: comma-separated iface=path pairs
# The 99-vpn-status hotplug script reads this to create/remove sentinel files
# when WireGuard interfaces go up/down on OpenWRT.
# VPN_STATUS_FILES=wg0=/run/wg0-active,wg1=/run/wg1-active

# Local networks for RX/TX direction detection (auto-discovered if not set)
# Override for SPAN ports or dynamic ISP prefixes
# LOCAL_NETS=192.0.2.0/24,2001:db8::/48

# SPAN/mirror port: override RX/TX direction on this interface using pcap.
# Requires LOCAL_NETS to be set. Other interfaces keep normal /proc/net/dev stats.
# SPAN_DEVICE=eth1

## Diagnostics

# Speed test target server
# SPEEDTEST_SERVER=https://speed.ffmuc.net

# Latency monitoring: comma-separated hostnames/IPs to probe via ICMP + HTTPS.
# Defaults to anycast01.ffmuc.net, anycast02.ffmuc.net, dns.quad9.net, dns3.digitalcourage.de if not set.
# LATENCY_TARGETS=anycast01.ffmuc.net,anycast02.ffmuc.net,dns.quad9.net,dns3.digitalcourage.de
